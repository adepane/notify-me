# --- notify-me: global defaults -------------------------------------------
EXCEPTION_NOTIFIER_FORMAT=markdown        # markdown | plain
EXCEPTION_NOTIFIER_MAX_TRACE_LINES=15
EXCEPTION_NOTIFIER_LEVEL=error            # debug|info|notice|warning|error|critical|alert|emergency

# Auto-notify every reported exception (no config/logging.php wiring needed).
# On by default; set to false to disable entirely.
EXCEPTION_NOTIFIER_AUTO_REPORT=true

# --- Telegram --------------------------------------------------------------
TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_bot_token_here
TELEGRAM_CHAT_ID=-1001234567890
# TELEGRAM_FORMAT=markdown
# TELEGRAM_LEVEL=error
# TELEGRAM_MAX_TRACE_LINES=15
# TELEGRAM_TIMEOUT=5

# --- Discord ---------------------------------------------------------------
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/000/xxxxxxxx
# DISCORD_FORMAT=markdown
# DISCORD_LEVEL=error
# DISCORD_MAX_TRACE_LINES=15
# DISCORD_TIMEOUT=5

# --- Slack -----------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/XXXXXXXX
# SLACK_FORMAT=markdown
# SLACK_LEVEL=error
# SLACK_MAX_TRACE_LINES=15
# SLACK_TIMEOUT=5
